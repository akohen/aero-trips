{
  "name": "aero-trips",
  "private": true,
  "version": "0.23.3",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "postbuild": "tsx scripts/prerender.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "backup": "npx -p node-firestore-import-export firestore-export -a serviceAccountKey.json -b backups/$(date +\"%Y-%m-%d\").json",
    "export": "NODE_ENV=production tsx scripts/export-data.ts",
    "import": "NODE_ENV=production tsx scripts/import-data.ts",
    "manage": "NODE_ENV=production node scripts/manage-edits.js",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/core": "^9.0.0",
    "@mantine/dates": "^9.0.1",
    "@mantine/form": "^9.0.1",
    "@mantine/hooks": "^9.0.0",
    "@mantine/tiptap": "^9.0.1",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-youtube": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@types/dompurify": "^3.0.5",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.0",
    "firebase": "^12.11.0",
    "haversine-distance": "^1.2.4",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@inquirer/prompts": "^8.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/html": "^3.22.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "chalk": "^5.6.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-xml-parser": "^5.5.10",
    "firebase-admin": "^13.7.0",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
